    {
      "id": "read-analyse",
      "name": "Sheets \u2014 Semantische Analyse lesen",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [500, 0],
      "parameters": {
        "operation": "read",
        "documentId": { "mode": "id", "value": "={{ $json.spreadsheet_id }}" },
        "sheetName": { "mode": "name", "value": "Semantische_Analyse" },
        "range": "A:Z",
        "options": {}
      }
    },
    {
      "id": "read-insights",
      "name": "Sheets \u2014 User Insights lesen",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [500, 200],
      "parameters": {
        "operation": "read",
        "documentId": { "mode": "id", "value": "={{ $json.spreadsheet_id }}" },
        "sheetName": { "mode": "name", "value": "User_Insights" },
        "range": "A:Z",
        "options": {}
      }
    },
    {
      "id": "merge-all-data",
      "name": "Alle Daten zusammenf\u00fchren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 0],
      "parameters": {
        "jsCode": "const keywords = $('Sheets \u2014 Keywords lesen').all().map(i => i.json);\nconst analyse = $('Sheets \u2014 Semantische Analyse lesen').all().map(i => i.json);\nconst insights = $('Sheets \u2014 User Insights lesen').all().map(i => i.json);\nconst spreadsheetId = $('WF5 Variablen').first().json.spreadsheet_id;\n\nconst selectedKeywords = keywords.filter(k => k.ausgewaehlt === 'ja');\nconst commodityTopics = analyse.filter(a => a.kategorie === 'pflicht');\nconst uniqueAngles = insights.filter(i => i.unique_angle === 'ja');\nconst expertInsights = insights.filter(i => i.quelle === 'expert_input');\nconst userQuestions = insights.filter(i => i.typ === 'frage');\n\nreturn [{\n  json: {\n    spreadsheet_id: spreadsheetId,\n    selected_keywords: JSON.stringify(selectedKeywords),\n    commodity_topics: JSON.stringify(commodityTopics),\n    unique_angles: JSON.stringify(uniqueAngles),\n    expert_insights: JSON.stringify(expertInsights),\n    user_questions: JSON.stringify(userQuestions),\n    all_analyse: JSON.stringify(analyse),\n    keyword_count: selectedKeywords.length,\n    commodity_count: commodityTopics.length,\n    unique_count: uniqueAngles.length\n  }\n}];"
      }
    },
    {
      "id": "claude-outline",
      "name": "Claude \u2014 Gliederung generieren",
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [1100, 0],
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": { "mode": "id", "value": "claude-sonnet-4-20250514" },
        "messages": {
          "values": [
            {
              "content": "=Erstelle eine Artikel-Gliederung:\n\nKEYWORDS ({{ $json.keyword_count }}): {{ $json.selected_keywords }}\n\nPFLICHTTHEMEN ({{ $json.commodity_count }}): {{ $json.commodity_topics }}\n\nUNIQUE ANGLES ({{ $json.unique_count }}): {{ $json.unique_angles }}\n\nEXPERT INSIGHTS: {{ $json.expert_insights }}\n\nUSER FRAGEN: {{ $json.user_questions }}\n\nANALYSE: {{ $json.all_analyse }}",
              "role": "user"
            }
          ]
        },
        "simplify": true,
        "options": {
          "system": "Du bist ein erfahrener SEO-Content-Stratege. Erstelle eine detaillierte Artikel-Gliederung basierend auf den bereitgestellten Daten. Die Gliederung muss:\n1. Alle Commodity Topics abdecken\n2. Unique Angles prominent einbauen\n3. Expert Insights integrieren\n4. User-Fragen als FAQ aufnehmen\n5. Logische H1 > H2 > H3 Hierarchie\n\nAntworte AUSSCHLIESSLICH im JSON-Format (Array von Objekten):\n[{\"position\": 1, \"ebene\": \"h1\", \"ueberschrift\": \"...\", \"typ\": \"einleitung|kerninfo|hauptteil|fehler|faq|fazit\", \"basiert_auf\": \"commodity|unique_angle|expert_take\", \"stichpunkte\": \"Punkt 1; Punkt 2; Punkt 3\"}]",
          "maxTokens": 4096
        }
      },
      "credentials": {
        "anthropicApi": { "id": "xJGzDv9YCgZEHb2E", "name": "Claude - 20260127" }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "id": "parse-outline",
      "name": "Gliederung parsen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1400, 0],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst spreadsheetId = $('WF5 Variablen').first().json.spreadsheet_id;\n\nlet content = '';\ntry {\n  content = response.content?.[0]?.text || response.content || '';\n} catch (e) {\n  content = JSON.stringify(response);\n}\n\nlet outline = [];\ntry {\n  const jsonMatch = content.match(/\\[\\s*\\{[\\s\\S]*\\}\\s*\\]/);\n  if (jsonMatch) {\n    outline = JSON.parse(jsonMatch[0]);\n  } else {\n    outline = JSON.parse(content);\n  }\n} catch (e) {\n  outline = [{ position: 1, ebene: 'h1', ueberschrift: 'Parsing fehlgeschlagen', typ: 'hauptteil', basiert_auf: 'commodity', stichpunkte: content.slice(0, 500) }];\n}\n\nreturn outline.map(item => ({\n  json: {\n    position: item.position || 0,\n    ebene: item.ebene || 'h2',\n    ueberschrift: item.ueberschrift || '',\n    typ: item.typ || 'hauptteil',\n    basiert_auf: item.basiert_auf || 'commodity',\n    stichpunkte: item.stichpunkte || '',\n    freigabe: 'nein',\n    spreadsheet_id: spreadsheetId\n  }\n}));"
      }
    },
    {
      "id": "write-outline",
      "name": "Sheets \u2014 Gliederung schreiben",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [1650, 0],
      "parameters": {
        "operation": "append",
        "documentId": { "__rl": true, "mode": "id", "value": "={{ $json.spreadsheet_id }}" },
        "sheetName": { "__rl": true, "mode": "name", "value": "Gliederung" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "position": "={{ $json.position }}",
            "ebene": "={{ $json.ebene }}",
            "ueberschrift": "={{ $json.ueberschrift }}",
            "typ": "={{ $json.typ }}",
            "basiert_auf": "={{ $json.basiert_auf }}",
            "stichpunkte": "={{ $json.stichpunkte }}",
            "freigabe": "={{ $json.freigabe }}"
          },
          "schema": [
            { "id": "position", "type": "string", "display": true, "displayName": "position" },
            { "id": "ebene", "type": "string", "display": true, "displayName": "ebene" },
            { "id": "ueberschrift", "type": "string", "display": true, "displayName": "ueberschrift" },
            { "id": "typ", "type": "string", "display": true, "displayName": "typ" },
            { "id": "basiert_auf", "type": "string", "display": true, "displayName": "basiert_auf" },
            { "id": "stichpunkte", "type": "string", "display": true, "displayName": "stichpunkte" },
            { "id": "freigabe", "type": "string", "display": true, "displayName": "freigabe" }
          ]
        },
        "options": {}
      }
    },
