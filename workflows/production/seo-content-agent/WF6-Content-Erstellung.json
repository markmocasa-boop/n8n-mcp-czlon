    {
      "id": "prepare-sections",
      "name": "Sektionen vorbereiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "let gliederung = [];\ntry { gliederung = $('Sheets — Gliederung lesen').all().map(i => i.json); } catch(e) {}\nlet analyse = [];\ntry { analyse = $('Sheets — Analyse lesen').all().map(i => i.json); } catch(e) {}\nconst spreadsheetId = $('WF6 Variablen').first().json.spreadsheet_id;\nif (gliederung.length === 0) { return [{ json: { error: 'Keine Gliederung', spreadsheet_id: spreadsheetId } }]; }\nconst sections = gliederung.filter(g => g.freigabe === 'ja' || g.freigabe === 'angepasst');\nconst activeSections = sections.length > 0 ? sections : gliederung;\nconst outlineContext = activeSections.map(s => `${s.ebene}: ${s.ueberschrift} (${s.typ}) - ${s.stichpunkte}`).join('\\n');\nconst analyseContext = analyse.map(a => `[${a.kategorie}] ${a.keyword_oder_thema}: ${a.details}`).join('\\n');\nreturn activeSections.map(section => ({ json: { position: section.position, ebene: section.ebene, ueberschrift: section.ueberschrift, typ: section.typ, stichpunkte: section.stichpunkte, basiert_auf: section.basiert_auf, outline_context: outlineContext, analyse_context: analyseContext, spreadsheet_id: spreadsheetId } }));"
      }
    },
    {
      "id": "section-batch",
      "name": "Sektionen einzeln verarbeiten",
      "type": "n8n-nodes-base.splitInBatches",
