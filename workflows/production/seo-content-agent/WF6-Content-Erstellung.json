      }
    },
    {
      "id": "claude-write",
      "name": "Claude — Sektion schreiben",
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [
        1300,
        0
      ],
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "mode": "id",
          "value": "claude-sonnet-4-20250514"
        },
        "messages": {
          "values": [
            {
              "content": "=Schreibe den folgenden Abschnitt:\n\nÜBERSCHRIFT: {{ $json.ueberschrift }}\nEBENE: {{ $json.ebene }}\nTYP: {{ $json.typ }}\nSTICHPUNKTE: {{ $json.stichpunkte }}\nBASIS: {{ $json.basiert_auf }}\n\nGESAMTE GLIEDERUNG:\n{{ $json.outline_context }}\n\nSEMANTISCHE ANALYSE:\n{{ $json.analyse_context }}",
              "role": "user"
            }
          ]
        },
        "simplify": true,
        "options": {
          "system": "Du bist ein erfahrener SEO-Texter. Schreibe einen Artikel-Abschnitt in natürlichem, lesbarem Deutsch.",
          "maxTokens": 3000
        }
      },
      "credentials": {
        "anthropicApi": {
          "id": "xJGzDv9YCgZEHb2E",
          "name": "Claude - 20260127"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "id": "extract-content",
      "name": "Content extrahieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1550,
        0
      ],
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst sectionData = $('Sektionen einzeln verarbeiten').first().json;\nlet content = '';\ntry { content = response.content?.[0]?.text || response.content || ''; } catch (e) { content = 'Fehler: ' + e.message; }\nreturn [{ json: { abschnitt: sectionData.ueberschrift, position: sectionData.position, ebene: sectionData.ebene, content_raw: content, content_humanized: '', content_final: '', spreadsheet_id: sectionData.spreadsheet_id } }];"
      }
    },
    {
      "id": "write-draft",
      "name": "Sheets — Content Draft schreiben",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1800,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "=https://sheets.googleapis.com/v4/spreadsheets/{{ $json.spreadsheet_id }}/values/Content%20Draft!A:D:append",
        "sendQuery": true,
        "queryParameters": {
