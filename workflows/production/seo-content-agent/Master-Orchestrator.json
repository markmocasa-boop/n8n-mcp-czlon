            {"id": "zielsprache", "name": "zielsprache", "value": "={{ $json['Zielsprache'] }}", "type": "string"},
            {"id": "url_slug", "name": "url_slug", "value": "={{ $json['Ziel-URL-Slug'] || '' }}", "type": "string"},
