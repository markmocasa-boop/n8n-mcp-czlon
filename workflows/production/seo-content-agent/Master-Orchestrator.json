    },
    {"id": "exec-wf1", "name": "WF1 — Projekt-Setup & Keywords", "type": "n8n-nodes-base.executeWorkflow", "typeVersion": 1.2, "position": [500, 0], "parameters": {"source": "database", "workflowId": "1FZxfz2bGwkLLvPv", "options": {"waitForSubWorkflow": true}}},
    {
      "id": "extract-spreadsheet-id",
      "name": "Spreadsheet-ID extrahieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [750, 0],
      "parameters": {
        "jsCode": "var items = $input.all();\nvar spreadsheetId = '';\nfor (var i = 0; i < items.length; i++) {\n  var json = items[i].json;\n  if (json.spreadsheet_id) {\n    spreadsheetId = json.spreadsheet_id;\n    break;\n  }\n}\nif (!spreadsheetId) {\n  try {\n    var firstItem = items[0].json;\n    spreadsheetId = firstItem.spreadsheet_id || firstItem.projekt_id || '';\n  } catch(e) {}\n}\nreturn [{ json: { spreadsheet_id: spreadsheetId, status: 'wf1_complete' } }];"
      }
    },
    {
      "id": "form-keyword-auswahl",
      "name": "Keyword-Auswahl",
      "type": "n8n-nodes-base.form",
      "typeVersion": 1,
      "position": [1000, 0],
      "parameters": {
        "formTitle": "Phase 2: Keyword-Auswahl",
        "formDescription": "WF1 ist abgeschlossen. Keywords wurden in Google Sheets geschrieben.\n\n1. Oeffne das Google Sheet und pruefe die Keywords im Tab 'Keywords'\n2. Markiere die gewuenschten Keywords in der Spalte 'ausgewaehlt' mit 'ja'\n3. Setze Prioritaeten (1-5) in der Spalte 'prioritaet'\n4. Komme zurueck und klicke 'Weiter'",
        "formFields": {
          "values": [
            {"fieldLabel": "Zusaetzliche Custom-Keywords", "fieldType": "textarea", "requiredField": false, "placeholder": "Ein Keyword pro Zeile (optional)"},
            {"fieldLabel": "Notizen zur Suchintention", "fieldType": "textarea", "requiredField": false, "placeholder": "z.B. Fokus auf informational keywords"}
          ]
        },
        "options": {"buttonLabel": "Keywords bestaetigen & SERP starten"}
      }
    },
