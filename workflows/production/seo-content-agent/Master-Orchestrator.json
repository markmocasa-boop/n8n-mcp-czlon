          "values": [
            {"fieldLabel": "Thema / Titel", "fieldType": "text", "requiredField": true, "placeholder": "z.B. Keyword-Recherche Guide 2025"},
            {"fieldLabel": "Zielsprache", "fieldType": "dropdown", "requiredField": true, "fieldOptions": {"values": [{"option": "DE"}, {"option": "EN"}]}},
            {"fieldLabel": "Ziel-URL-Slug", "fieldType": "text", "requiredField": false, "placeholder": "z.B. keyword-recherche-guide"},
            {"fieldLabel": "Notizen", "fieldType": "textarea", "requiredField": false, "placeholder": "Zusaetzliche Hinweise zum Artikel"}
          ]
        },
        "options": {"buttonLabel": "Projekt starten", "respondWithData": false}
      }
    },
    {
      "id": "set-start-vars",
