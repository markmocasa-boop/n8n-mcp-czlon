            { "id": "schwierigkeit", "type": "string", "display": true, "displayName": "schwierigkeit" },
            { "id": "suchintention", "type": "string", "display": true, "displayName": "suchintention" },
            { "id": "prioritaet", "type": "string", "display": true, "displayName": "prioritaet" },
            { "id": "ausgewaehlt", "type": "string", "display": true, "displayName": "ausgewaehlt" }
          ]
        },
        "options": {}
