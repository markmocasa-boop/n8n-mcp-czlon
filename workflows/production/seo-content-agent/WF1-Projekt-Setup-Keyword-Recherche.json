      "id": "dataforseo-matching",
      "name": "DataForSEO — Matching Keywords",
      "type": "n8n-nodes-dataforseo.dataForSeo",
      "typeVersion": 1,
      "position": [800, -300],
      "credentials": {
        "dataForSeoApi": { "id": "7moI5XcUYmWsWlQ0", "name": "DataForSEO account" }
      },
      "notes": "DataForSEO native Node: related_keywords — findet thematisch passende Keywords",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000
    },
    {
      "parameters": {
        "resource": "labs",
        "operation": "get-keyword-suggestions",
        "keyword": "={{ $('Projekt-Variablen setzen').first().json.thema }}",
        "location_name_required": "={{ $('Projekt-Variablen setzen').first().json.dataforseo_location }}",
        "language_name_required": "={{ $('Projekt-Variablen setzen').first().json.dataforseo_language }}",
        "limit": 30,
        "order_by": ["keyword_info.search_volume,desc"]
      },
      "id": "dataforseo-suggestions",
      "name": "DataForSEO — Keyword Suggestions",
      "type": "n8n-nodes-dataforseo.dataForSeo",
      "typeVersion": 1,
      "position": [800, -100],
      "credentials": {
        "dataForSeoApi": { "id": "7moI5XcUYmWsWlQ0", "name": "DataForSEO account" }
      },
      "notes": "DataForSEO native Node: keyword_suggestions — verwandte Keyword-Vorschläge",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst items = [];\n\ntry {\n  const tasks = input.tasks || [];\n  for (const task of tasks) {\n    const result = task.result || [];\n    for (const r of result) {\n      const kwItems = r.items || [];\n      for (const item of kwItems) {\n        const kw = item.keyword_data || item;\n        items.push({\n          json: {\n            keyword: kw.keyword || item.keyword || '',\n            typ: 'matching',\n            suchvolumen: kw.keyword_info?.search_volume || kw.search_volume || 0,\n            schwierigkeit: kw.keyword_info?.keyword_difficulty || kw.keyword_difficulty || 0,\n            suchintention: (kw.search_intent_info?.main_intent || kw.keyword_info?.search_intent || 'informational').toLowerCase(),\n            cpc: kw.keyword_info?.cpc || kw.cpc || 0,\n            prioritaet: '',\n            ausgewaehlt: 'nein'\n          }\n        });\n      }\n    }\n  }\n} catch (e) {\n  items.push({ json: { error: e.message, raw: JSON.stringify(input).slice(0, 500) } });\n}\n\nif (items.length === 0) {\n  items.push({ json: { keyword: 'Keine Ergebnisse', typ: 'matching', suchvolumen: 0, schwierigkeit: 0, suchintention: '', cpc: 0, prioritaet: '', ausgewaehlt: 'nein' } });\n}\n\nreturn items;"
      },
      "id": "process-matching",
      "name": "Matching Keywords verarbeiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, -300],
      "notes": "Extrahiert Keywords aus DataForSEO related_keywords Response"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst items = [];\n\ntry {\n  const tasks = input.tasks || [];\n  for (const task of tasks) {\n    const result = task.result || [];\n    for (const r of result) {\n      const kwItems = r.items || [];\n      for (const item of kwItems) {\n        items.push({\n          json: {\n            keyword: item.keyword || '',\n            typ: 'related',\n            suchvolumen: item.keyword_info?.search_volume || 0,\n            schwierigkeit: item.keyword_info?.keyword_difficulty || 0,\n            suchintention: (item.search_intent_info?.main_intent || item.keyword_info?.search_intent || 'informational').toLowerCase(),\n            cpc: item.keyword_info?.cpc || 0,\n            prioritaet: '',\n            ausgewaehlt: 'nein'\n          }\n        });\n      }\n    }\n  }\n} catch (e) {\n  items.push({ json: { error: e.message, raw: JSON.stringify(input).slice(0, 500) } });\n}\n\nif (items.length === 0) {\n  items.push({ json: { keyword: 'Keine Ergebnisse', typ: 'related', suchvolumen: 0, schwierigkeit: 0, suchintention: '', cpc: 0, prioritaet: '', ausgewaehlt: 'nein' } });\n}\n\nreturn items;"
      },
      "id": "process-suggestions",
      "name": "Suggestion Keywords verarbeiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, -100],
      "notes": "Extrahiert Keywords aus DataForSEO keyword_suggestions Response"
    },
    {
      "parameters": { "mode": "append" },
      "id": "merge-keywords",
      "name": "Keywords zusammenführen",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [1350, -200],
      "notes": "Kombiniert Matching + Related Keywords in einem Stream"
    },
    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst seen = new Map();\n\nfor (const item of allItems) {\n  const kw = (item.json.keyword || '').toLowerCase().trim();\n  if (!kw || kw === 'keine ergebnisse') continue;\n  \n  if (!seen.has(kw)) {\n    seen.set(kw, item.json);\n  } else {\n    const existing = seen.get(kw);\n    if ((item.json.suchvolumen || 0) > (existing.suchvolumen || 0)) {\n      seen.set(kw, item.json);\n    }\n  }\n}\n\nconst sorted = Array.from(seen.values())\n  .sort((a, b) => (b.suchvolumen || 0) - (a.suchvolumen || 0));\n\nreturn sorted.map(item => ({ json: item }));"
      },
      "id": "deduplicate-keywords",
      "name": "Duplikate entfernen & sortieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1600, -200],
      "notes": "Entfernt doppelte Keywords und sortiert nach Suchvolumen"
    },
    {
