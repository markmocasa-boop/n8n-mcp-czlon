      "id": "response-summary",
      "name": "Zusammenfassung für User",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [2350, -200],
      "notes": "Erstellt Zusammenfassung für Form-Response an den User"
