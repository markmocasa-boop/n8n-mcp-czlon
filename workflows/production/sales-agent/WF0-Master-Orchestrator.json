              "name": "lead_id",
              "type": "stringValue",
              "stringValue": "={{ $json.lead_id }}"
            },
            {
              "name": "updates",
              "type": "objectValue",
              "objectValue": "={{ { \"status\": \"Kalt\", \"score\": $json.score } }}"
            },
            {
              "name": "log_eintrag",
              "type": "objectValue",
              "objectValue": "={{ { \"aktion\": \"score_zu_niedrig\", \"inhalt\": \"Score: \" + $json.score + \" (unter 30)\" } }}"
            }
