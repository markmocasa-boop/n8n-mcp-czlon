    {
      "id": "e0a79df6-49ea-40ac-9017-874f264c009d",
      "name": "Statistik",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3750,
        450
      ],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst stats = { total: items.length, gruen: 0, gelb: 0, rot: 0, upgrades: [], downgrades: [] };\nfor (const item of items) {\n  const ampel = item.json.neue_ampel || 'GELB';\n  if (ampel === 'GRUEN') { stats.gruen++; stats.upgrades.push(item.json.Firmenname || 'Unbekannt'); }\n  else if (ampel === 'ROT') { stats.rot++; stats.downgrades.push(item.json.Firmenname || 'Unbekannt'); }\n  else { stats.gelb++; }\n}\nconst datum = $now.toFormat('dd.MM.yyyy');\nlet html = '<h2>Monatliche GELB-Pruefung (' + datum + ')</h2>';\nhtml += '<p><strong>Gesamt:</strong> ' + stats.total + ' Leads geprueft</p>';\nhtml += '<table border=\"1\" cellpadding=\"5\" style=\"border-collapse:collapse\">';\nhtml += '<tr><td>GRUEN (Upgrade)</td><td><strong>' + stats.gruen + '</strong></td></tr>';\nhtml += '<tr><td>GELB (unveraendert)</td><td><strong>' + stats.gelb + '</strong></td></tr>';\nhtml += '<tr><td>ROT (Downgrade)</td><td><strong>' + stats.rot + '</strong></td></tr>';\nhtml += '</table>';\nif (stats.upgrades.length > 0) { html += '<h3>Upgrades zu GRUEN:</h3><ul>'; stats.upgrades.forEach(f => html += '<li>' + f + '</li>'); html += '</ul>'; }\nif (stats.downgrades.length > 0) { html += '<h3>Downgrades zu ROT:</h3><ul>'; stats.downgrades.forEach(f => html += '<li>' + f + '</li>'); html += '</ul>'; }\nreturn [{ json: { ...stats, report_html: html, datum: datum } }];"
      }
    },
