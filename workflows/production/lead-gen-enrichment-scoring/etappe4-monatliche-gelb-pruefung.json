    {
      "id": "6b792b5b-9485-4f4b-aa38-dbfc17949862",
      "name": "Merge Suche",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1750,
        300
      ],
      "parameters": {
        "jsCode": "const leads = $('Prepare Leads').all();\nconst results = $input.all();\nreturn results.map((r, i) => {\n  const lead = leads[i]?.json || {};\n  const companies = r.json?.companies || [];\n  const company = companies[0] || null;\n  return {\n    json: {\n      ...lead,\n      cs_found: !!company,\n      cs_company_id: company?.id || null,\n      cs_company_name: company?.name || null\n    }\n  };\n});"
      }
    },
