    {
      "id": "1f05a43c-a79b-4658-9026-6114bdb80fec",
      "name": "Merge Bericht",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2500,
        200
      ],
      "parameters": {
        "jsCode": "const allLeads = $('Merge Suche').all();\nconst foundLeads = allLeads.filter(l => l.json.cs_found);\nconst reports = $input.all();\nreturn reports.map((report, i) => {\n  const lead = foundLeads[i]?.json || {};\n  const cs = report.json?.report?.creditScore?.currentCreditRating || {};\n  return {\n    json: {\n      ...lead,\n      cs_credit_score: cs.commonValue ?? 'N/A',\n      cs_credit_rating: cs.providerValue?.value ?? 'N/A',\n      cs_credit_limit: cs.creditLimit?.value ?? 0,\n      cs_insolvency: report.json?.report?.additionalInformation?.insolvencyFlag ?? false\n    }\n  };\n});"
      }
    },
