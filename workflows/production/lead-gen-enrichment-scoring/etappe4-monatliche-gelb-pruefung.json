    {
      "id": "17d8e8a2-1f57-4b3d-b01a-367e23cb623c",
      "name": "GPT Neu-Bewertung",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.1,
      "position": [
        3000,
        300
      ],
      "parameters": {
        "resource": "chat",
        "operation": "complete",
        "chatModel": "gpt-4o",
        "prompt": {
          "messages": {
            "values": [
              {
                "role": "system",
                "content": "Du bist ein B2B-Lead-Bewertungsexperte. Bewerte den folgenden GELB-Lead neu basierend auf den aktuellen Creditsafe-Daten.\n\nBewertungskriterien:\n- Credit Score > 50 und Rating A-C = GRUEN (aufwerten)\n- Credit Score 30-50 oder Rating D = GELB (beibehalten)\n- Credit Score < 30 oder Rating E-F oder Insolvenz = ROT (abwerten)\n- Keine Bonitaetsdaten verfuegbar = GELB (beibehalten)\n\nAntworte NUR als JSON:\n{\"neue_ampel\":\"GRUEN/GELB/ROT\",\"neuer_score\":0-100,\"begruendung\":\"...\",\"aenderung\":\"UPGRADE/KEINE/DOWNGRADE\"}"
              },
              {
                "role": "user",
                "content": "={{ 'Firmenname: ' + ($json.Firmenname || 'unbekannt') + '\\nBranche: ' + ($json.Branche || 'unbekannt') + '\\nAlte Ampel: GELB\\nCredit Score: ' + ($json.cs_credit_score || 'nicht verfuegbar') + '\\nCredit Rating: ' + ($json.cs_credit_rating || 'nicht verfuegbar') + '\\nCredit Limit: ' + ($json.cs_credit_limit || '0') + '\\nInsolvenz: ' + ($json.cs_insolvency || 'false') }}"
              }
            ]
          }
        },
        "options": {
          "temperature": 0.2,
          "maxTokens": 500
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "",
          "name": ""
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "id": "d20b774b-c5c1-4e81-bc2b-d0a47c436820",
      "name": "Parse Bewertung",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3250,
        300
      ],
      "parameters": {
        "jsCode": "const leads = $('Merge Bonität').all();\nconst responses = $input.all();\nreturn responses.map((r, i) => {\n  const lead = leads[i]?.json || {};\n  try {\n    const content = r.json.content || r.json.message?.content || '';\n    const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) {\n      const b = JSON.parse(jsonMatch[0]);\n      return { json: { ...lead, neue_ampel: b.neue_ampel || 'GELB', neuer_score: b.neuer_score || 50, begruendung: b.begruendung || '', aenderung: b.aenderung || 'KEINE', letzte_pruefung: $now.toISO() } };\n    }\n  } catch(e) {}\n  return { json: { ...lead, neue_ampel: 'GELB', neuer_score: 50, begruendung: 'Parsing fehlgeschlagen', aenderung: 'KEINE', letzte_pruefung: $now.toISO() } };\n});"
      }
    },
