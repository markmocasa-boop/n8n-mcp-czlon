    {
      "id": "694b3da1-427d-47dc-a976-328b336b4d9c",
      "name": "Parse Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4600,
        200
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst enrichData = $('Merge Enrichment').first().json;\nconst results = [];\nfor (const item of items) {\n  try {\n    const content = item.json.content || '';\n    const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n    let summary = {};\n    if (jsonMatch) { summary = JSON.parse(jsonMatch[0]); } else { summary = { zusammenfassung: content }; }\n    const kontakt = (summary.kontaktpersonen && summary.kontaktpersonen[0]) || {};\n    const profil = summary.unternehmensprofil || {};\n    const verkauf = summary.verkaufschancen || {};\n    results.push({ json: { firmenname: enrichData.firmenname, branche: enrichData.branche, score: enrichData.score, ampel: enrichData.ampel, kontaktperson: kontakt.name || (enrichData.extrahierte_daten ? enrichData.extrahierte_daten.name : '') || '', position: kontakt.position || '', email: (enrichData.extrahierte_daten ? enrichData.extrahierte_daten.email : '') || kontakt.email || '', telefon: enrichData.extrahierte_daten ? (enrichData.extrahierte_daten.telefon || '') : '', website: profil.website || '', linkedin_url: profil.linkedin || '', zusammenfassung: summary.zusammenfassung || '', verkaufspotenzial: verkauf.potenzial || '', bedarfe: (verkauf.bedarfe || []).join(', '), pain_points: (verkauf.pain_points || []).join(', '), empfohlene_ansprache: summary.empfohlene_ansprache || '', aktuelle_news: (summary.aktuelle_news || []).join('; '), wettbewerber: (summary.wettbewerber || []).join(', '), quellen: enrichData.quellen_verfuegbar.join(', '), enrichment_datum: enrichData.enrichment_datum, enrichment: enrichData.enrichment, lead_summary: summary, original_email: enrichData.original_email, extrahierte_daten: enrichData.extrahierte_daten } });\n  } catch (e) {\n    results.push({ json: { firmenname: enrichData.firmenname, branche: enrichData.branche, score: enrichData.score, zusammenfassung: 'Fehler: ' + e.message, enrichment: enrichData.enrichment, original_email: enrichData.original_email, extrahierte_daten: enrichData.extrahierte_daten } });\n  }\n}\nreturn results;"
      }
    },
