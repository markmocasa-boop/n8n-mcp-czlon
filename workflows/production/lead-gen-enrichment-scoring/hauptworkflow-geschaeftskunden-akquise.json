      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst leadData = $('Parse Summary').first().json;\nconst results = [];\nfor (const item of items) {\n  try {\n    const content = item.json.content || '';\n    const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) {\n      const emails = JSON.parse(jsonMatch[0]);\n      results.push({ json: { ...leadData, email1_subject: emails.email1_subject, email1_body: emails.email1_body, email2_subject: emails.email2_subject, email2_body: emails.email2_body, email3_subject: emails.email3_subject, email3_body: emails.email3_body, email4_subject: emails.email4_subject, email4_body: emails.email4_body, basho_generated: true, basho_start: $now.toISO() } });\n    } else {\n      results.push({ json: { ...leadData, email1_subject: 'Zusammenarbeit mit ' + (leadData.firmenname || 'Ihrem Unternehmen'), email1_body: '<p>Guten Tag,</p><p>ich moechte mich vorstellen.</p><p>{{ABSENDER_NAME}}<br>{{FIRMA}}<br>{{TELEFON}}</p>', email2_subject: 'Follow-up', email2_body: '<p>Guten Tag,</p><p>kurzes Nachhaken.</p><p>{{ABSENDER_NAME}}<br>{{FIRMA}}<br>{{TELEFON}}</p>', email3_subject: 'Kurze Frage', email3_body: '<p>Guten Tag,</p><p>ist das Thema relevant?</p><p>{{ABSENDER_NAME}}<br>{{FIRMA}}<br>{{TELEFON}}</p>', email4_subject: 'Abschluss', email4_body: '<p>Guten Tag,</p><p>bei Interesse melden.</p><p>{{ABSENDER_NAME}}<br>{{FIRMA}}<br>{{TELEFON}}</p>', basho_generated: false } });\n    }\n  } catch (e) {\n    results.push({ json: { ...leadData, email1_subject: 'Zusammenarbeit', email1_body: '<p>Vorstellung.</p>', email2_subject: 'Follow-up', email2_body: '<p>Nachhaken.</p>', email3_subject: 'Frage', email3_body: '<p>Relevant?</p>', email4_subject: 'Abschluss', email4_body: '<p>Bei Interesse melden.</p>', basho_generated: false, basho_error: e.message } });\n  }\n}\nreturn results;"
      }
    },
