    {
      "id": "d8b7f495-e30a-423e-9852-954eeee6fc04",
      "name": "Merge Enrichment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4100,
        200
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const ampelData = $('Parse Ampel').first().json;\nlet apollo = {}; try { apollo = $('Apollo Enrichment').first().json; } catch(e) { apollo = { error: true }; }\nlet linkedin = {}; try { linkedin = $('Apify LinkedIn').first().json; } catch(e) { linkedin = { error: true }; }\nlet tavily = {}; try { tavily = $('Tavily Suche').first().json; } catch(e) { tavily = { error: true }; }\nlet perplexity = {}; try { perplexity = $('Perplexity Analyse').first().json; } catch(e) { perplexity = { error: true }; }\nconst quellen = [];\nif (!apollo.error) quellen.push('Apollo');\nif (!linkedin.error) quellen.push('LinkedIn');\nif (!tavily.error) quellen.push('Tavily');\nif (!perplexity.error) quellen.push('Perplexity');\nreturn [{ json: { firmenname: ampelData.firmenname, branche: ampelData.branche, extrahierte_daten: ampelData.extrahierte_daten, original_email: ampelData.original_email, ampel: ampelData.ampel, score: ampelData.score, ampel_begruendung: ampelData.ampel_begruendung, risikofaktoren: ampelData.risikofaktoren, empfehlung: ampelData.empfehlung, enrichment: { apollo, linkedin, tavily, perplexity }, enrichment_datum: $now.toISO(), quellen_verfuegbar: quellen } }];"
      }
    },
