      "position": [
        2500,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst classData = $('Parse Klassifikation').first().json;\nconst extractData = $('Firma extrahieren').first().json;\nlet csReport = {};\ntry { csReport = $('Creditsafe Bericht').first().json; } catch(e) {}\nconst results = [];\nfor (const item of items) {\n  try {\n    const content = item.json.content || '';\n    const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) {\n      const parsed = JSON.parse(jsonMatch[0]);\n      results.push({ json: { firmenname: classData.firmenname, branche: classData.branche, extrahierte_daten: classData.extrahierte_daten, original_email: classData.original_email, company_id: extractData.company_id, company_found: extractData.company_found, creditsafe_error: extractData.creditsafe_error, ampel: parsed.ampel, score: parsed.score, ampel_begruendung: parsed.begruendung, risikofaktoren: parsed.risikofaktoren, empfehlung: parsed.empfehlung, creditsafe_raw: csReport } });\n    } else {\n      results.push({ json: { firmenname: classData.firmenname, branche: classData.branche, extrahierte_daten: classData.extrahierte_daten, original_email: classData.original_email, ampel: 'GELB', score: 0, ampel_begruendung: 'GPT nicht parsbar', risikofaktoren: ['Parse-Fehler'], empfehlung: 'Manuelle Prüfung' } });\n    }\n  } catch (e) {\n    results.push({ json: { firmenname: classData.firmenname, branche: classData.branche, extrahierte_daten: classData.extrahierte_daten, original_email: classData.original_email, ampel: 'GELB', score: 0, ampel_begruendung: 'Fehler: ' + e.message, risikofaktoren: ['Fehler'], empfehlung: 'Manuelle Prüfung' } });\n  }\n}\nreturn results;"
      }
    },
