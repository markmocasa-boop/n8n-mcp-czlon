        300
      ],
      "parameters": {
        "resource": "chat",
        "operation": "complete",
        "chatModel": "gpt-4o",
        "prompt": {
          "messages": {
            "values": [
              {
                "role": "system",
                "content": "Du bist ein Experte für die Analyse von Bestellbestätigungen. Analysiere den folgenden Email-Text und bestimme, ob der Besteller ein Geschäftskunde (B2B) oder ein Privatkunde (B2C) ist.\n\nKriterien für Geschäftskunde:\n- Firmenname in der Adresse\n- USt-IdNr. / Steuernummer vorhanden\n- Gewerbliche Lieferadresse\n- Bestellmenge deutet auf gewerbliche Nutzung hin\n- Branchenspezifische Begriffe\n- \"Firma\", \"GmbH\", \"UG\", \"AG\", \"e.K.\", \"OHG\", \"KG\" im Namen\n\nAntworte als JSON:\n{\"ist_geschaeftskunde\":true/false,\"konfidenz\":0.0-1.0,\"firmenname\":\"Name oder null\",\"branche\":\"Branche oder null\",\"begruendung\":\"...\",\"extrahierte_daten\":{\"name\":\"\",\"email\":\"\",\"adresse\":\"\",\"telefon\":null,\"ust_id\":null}}"
              },
              {
                "role": "user",
                "content": "={{ $json.text }}"
              }
            ]
          }
        },
        "simplifyOutput": true,
        "options": {
          "temperature": 0.1,
          "maxTokens": 2000
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "",
          "name": ""
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "id": "89854318-8af8-4fc7-b2fd-67197b2ada81",
      "name": "Parse Klassifikation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst emailData = $('Email Trigger').first().json;\nconst results = [];\nfor (const item of items) {\n  try {\n    const content = item.json.content || '';\n    const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) {\n      const parsed = JSON.parse(jsonMatch[0]);\n      results.push({ json: { ...parsed, original_email: { from: emailData.from, subject: emailData.subject, date: emailData.date, text: emailData.text } } });\n    } else {\n      results.push({ json: { ist_geschaeftskunde: false, konfidenz: 0, firmenname: null, branche: null, begruendung: 'Kein JSON gefunden', extrahierte_daten: {}, original_email: { from: emailData.from, subject: emailData.subject, date: emailData.date } } });\n    }\n  } catch (e) {\n    results.push({ json: { ist_geschaeftskunde: false, konfidenz: 0, firmenname: null, branche: null, begruendung: 'Parse-Fehler: ' + e.message, extrahierte_daten: {}, original_email: { from: emailData.from, subject: emailData.subject, date: emailData.date } } });\n  }\n}\nreturn results;"
      }
    },
