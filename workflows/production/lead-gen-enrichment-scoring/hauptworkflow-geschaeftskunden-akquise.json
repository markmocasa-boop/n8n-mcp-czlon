    {
      "id": "4e1e0975-59cb-4ea6-a85a-18745ecb7452",
      "name": "Firma extrahieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1750,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst classData = $('Parse Klassifikation').first().json;\nlet authToken = null;\ntry { authToken = $('Creditsafe Auth').first().json.token; } catch(e) {}\nconst results = [];\nfor (const item of items) {\n  const companies = item.json.companies || [];\n  if (!authToken) {\n    results.push({ json: { ...classData, creditsafe_error: true, creditsafe_error_msg: 'Auth fehlgeschlagen', company_id: null, company_found: false } });\n  } else if (companies.length > 0) {\n    results.push({ json: { ...classData, creditsafe_error: false, company_id: companies[0].id, company_name_cs: companies[0].name, company_found: true } });\n  } else {\n    results.push({ json: { ...classData, creditsafe_error: true, creditsafe_error_msg: 'Keine Firma gefunden', company_id: null, company_found: false } });\n  }\n}\nreturn results;"
      }
