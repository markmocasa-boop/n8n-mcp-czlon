    {
      "id": "node-filter-contacts",
      "name": "Filter Contacts",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [660, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "cond-position-pass",
              "leftValue": "={{ ($('Form Trigger').item.json['Position (enthält)'] === '' || $('Form Trigger').item.json['Position (enthält)'] === undefined || $('Form Trigger').item.json['Position (enthält)'] === null) || ($json['Position'] && $json['Position'].toLowerCase().includes(($('Form Trigger').item.json['Position (enthält)'] || '').toLowerCase())) }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            },
            {
              "id": "cond-region-pass",
              "leftValue": "={{ ($('Form Trigger').item.json['Region (enthält)'] === '' || $('Form Trigger').item.json['Region (enthält)'] === undefined || $('Form Trigger').item.json['Region (enthält)'] === null) }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            },
            {
              "id": "cond-branche-pass",
              "leftValue": "={{ ($('Form Trigger').item.json['Branche (enthält)'] === '' || $('Form Trigger').item.json['Branche (enthält)'] === undefined || $('Form Trigger').item.json['Branche (enthält)'] === null) || ($json['Company'] && $json['Company'].toLowerCase().includes(($('Form Trigger').item.json['Branche (enthält)'] || '').toLowerCase())) }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            },
            {
              "id": "cond-mitarbeiter-pass",
              "leftValue": "={{ ($('Form Trigger').item.json['Mitarbeiteranzahl (enthält)'] === '' || $('Form Trigger').item.json['Mitarbeiteranzahl (enthält)'] === undefined || $('Form Trigger').item.json['Mitarbeiteranzahl (enthält)'] === null) }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "looseTypeValidation": true,
        "options": {}
      }
    },
    {
