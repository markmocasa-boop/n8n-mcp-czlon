      "name": "Scrape LinkedIn Profile",
      "type": "@apify/n8n-nodes-apify.apify",
      "typeVersion": 1,
      "position": [1500, 300],
      "onError": "continueErrorOutput",
      "credentials": {
        "apifyApi": {
          "id": "wWgQDWC9aV3UcUEJ",
          "name": "Apify MN1975"
        }
      },
      "parameters": {
        "resource": "Actors",
        "operation": "Run an Actor and Get Dataset",
        "actorId": "apify/linkedin-profile-scraper",
        "body": "={{ JSON.stringify({ \"startUrls\": [{ \"url\": $('Loop Contacts').item.json['URL'] }] }) }}"
      }
