    {
      "parameters": {
        "jsCode": "const batchItem = $('URL fuer URL verarbeiten').first().json;\nconst scraped = $input.first();\nconst config = $('Konfiguration').first().json;\n\nconst url = batchItem.url || batchItem.URL || batchItem.Url || '';\nconst keyword = batchItem.keyword || batchItem.Keyword || batchItem.KEYWORD || '';\nconst landescode = (batchItem.landescode || batchItem.Landescode || batchItem.LANDESCODE || 'DE').toUpperCase();\nconst email_empfaenger = config.email_empfaenger || '';\nconst zielsprache = config.zielsprache || 'DE';\n\nconst s = scraped.json;\nconst page_title = s.pageTitle || '';\n\nlet headings_structure = '';\nif (s.headings && Array.isArray(s.headings)) {\n  headings_structure = s.headings\n    .map(function(h) { return (h.tag || '').toUpperCase() + ': ' + (h.text || ''); })\n    .join(String.fromCharCode(10));\n}\n\nlet original_content = s.content || s.text || s.markdown || '';\nif (!original_content || original_content.length < 50) {\n  original_content = '[Scraping fehlgeschlagen fuer URL: ' + url + ']';\n}\nif (original_content.length > 12000) {\n  original_content = original_content.slice(0, 12000) + '...[gekuerzt]';\n}\n\nreturn [{ json: { url, keyword, landescode, original_content, headings_structure, page_title, email_empfaenger, zielsprache } }];"
      },
