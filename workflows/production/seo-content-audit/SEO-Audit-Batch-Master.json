    {
      "parameters": {
        "operation": "Run actor and get dataset",
        "actorId": {
          "__rl": true,
          "value": "YrQuEkowkNCLdk4j2",
          "mode": "list",
          "cachedResultName": "Cheerio Scraper (apify/cheerio-scraper)",
          "cachedResultUrl": "https://console.apify.com/actors/YrQuEkowkNCLdk4j2/input"
        },
        "customBody": "={{\nJSON.stringify({\n  startUrls: [{\n    url: $json.URL,\n    userData: { serpTitle: $json.title, serpSnippet: $json.snippet }\n  }],\n  maxRequestsPerCrawl: 1,\n  excludes: [{ glob: \"/**/*.{png,jpg,jpeg,pdf,svg,gif,webp}\" }],\n  pageFunction: `async function pageFunction(context) {\n    const { $, request } = context;\n\n    // Raus mit Noise\n    $('script,style,noscript,svg,nav,footer,header,aside').remove();\n    const $scope = $('main').length ? $('main') : $('body');\n\n    // Headings\n    const headings = [];\n    $scope.find('h1,h2,h3').each((_, el) => {\n      const tag = (el.name || '').toLowerCase();\n      const text = $(el).text().trim().replace(/\\\\s+/g, ' ');\n      if (text) headings.push({ tag, text });\n    });\n\n    // Paragraph-Content + Wordcount\n    const paragraphs = $scope.find('p').map((i, el) => $(el).text().trim()).get();\n    const content = paragraphs.join(' ').replace(/\\\\s+/g, ' ').trim();\n    const wordCount = content ? content.split(/\\\\s+/).length : 0;\n\n    const { serpTitle, serpSnippet } = request.userData || {};\n    return {\n      url: request.url,\n      pageTitle: $('title').first().text().trim(),\n      serpTitle, serpSnippet,\n      headings,\n      content,\n      wordCount\n    };\n  }`\n})\n}}\n"
      },
