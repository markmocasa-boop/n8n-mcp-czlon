      "name": "Parse Instagram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        140
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const platformData = $('Plattform Dispatcher').first().json;\nconst results = $input.all();\nconst parsed = results.map(r => {\n  const d = r.json;\n  return { platform: 'instagram', accountId: platformData.accountId, accountName: d.username || platformData.accountName, followers: d.followersCount || 0, following: d.followsCount || 0, posts: d.postsCount || 0, engagement_rate: d.followersCount > 0 ? ((d.likesCount || 0) + (d.commentsCount || 0)) / d.followersCount * 100 : 0, avg_likes: d.avgLikes || 0, avg_comments: d.avgComments || 0, bio: d.biography || '', verified: d.verified || false, raw: JSON.stringify(d) };\n});\nreturn parsed.map(p => ({ json: { ...platformData, ...p } }));"
      }
    },
    {
      "id": "sp1-parse-fb",
      "name": "Parse Facebook",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const platformData = $('Plattform Dispatcher').first().json;\nconst results = $input.all();\n// Facebook Insights returns { data: [ { name, values: [{value, end_time}] }, ... ] }\nconst metrics = {};\nfor (const r of results) {\n  const d = r.json;\n  if (d.data && Array.isArray(d.data)) {\n    for (const metric of d.data) {\n      const latestVal = metric.values && metric.values.length > 0\n        ? (metric.values[metric.values.length - 1].value || 0)\n        : 0;\n      metrics[metric.name] = typeof latestVal === 'object' ? Object.values(latestVal).reduce((a, b) => a + b, 0) : latestVal;\n    }\n  }\n}\nreturn [{ json: {\n  ...platformData,\n  platform: 'facebook',\n  page_impressions: metrics['page_impressions'] || 0,\n  page_reach: metrics['page_reach'] || 0,\n  page_fans: metrics['page_fans'] || 0,\n  page_engaged_users: metrics['page_engaged_users'] || 0,\n  post_engagements: metrics['page_post_engagements'] || 0,\n  raw: JSON.stringify(metrics)\n} }];"
      }
    },
