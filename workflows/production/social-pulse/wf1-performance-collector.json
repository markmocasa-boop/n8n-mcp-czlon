    {
      "id": "sp1-merge",
      "name": "Konfig zusammenfuehren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        780,
        460
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const webhookData = $('Webhook Trigger').first().json.body || {};\nlet config = {};\nlet accounts = [];\nif (webhookData.config) {\n  config = webhookData.config;\n  accounts = webhookData.accounts || [];\n} else {\n  try {\n    const konfigRows = $('Konfig aus Sheet lesen').all();\n    for (const row of konfigRows) {\n      const key = (row.json['Einstellung'] || row.json['einstellung'] || '').trim();\n      const val = (row.json['Wert'] || row.json['wert'] || '').trim();\n      if (key) config[key] = val;\n    }\n  } catch (e) {}\n  try {\n    accounts = $('Accounts aus Sheet lesen').all().map(r => r.json);\n  } catch (e) {}\n}\nconst now = new Date();\nconst startOfYear = new Date(now.getFullYear(), 0, 1);\nconst days = Math.floor((now - startOfYear) / (24 * 60 * 60 * 1000));\nconst calendarWeek = Math.ceil((days + startOfYear.getDay() + 1) / 7);\nreturn [{ json: { config, accounts, projectName: config.project_name || 'unknown', calendarWeek, year: now.getFullYear(), timestamp: now.toISOString() } }];"
      }
    },
    {
      "id": "sp1-dispatch",
      "name": "Plattform Dispatcher",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        460
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const input = $input.first().json;\nconst { accounts, config, projectName, calendarWeek, year, timestamp } = input;\nconst enabledPlatforms = (config.enabled_platforms || 'instagram,facebook,tiktok,linkedin,youtube,x_twitter').split(',').map(p => p.trim().toLowerCase());\nconst platformItems = [];\nfor (const account of accounts) {\n  const platform = (account.Plattform || account.plattform || '').toLowerCase();\n  if (enabledPlatforms.includes(platform) && (account.Account_ID || account.account_id || account.URL || account.url)) {\n    platformItems.push({ json: { platform, accountId: account.Account_ID || account.account_id || '', accountUrl: account.URL || account.url || '', accountName: account.Name || account.name || account.Account_ID || '', config, projectName, calendarWeek, year, timestamp } });\n  }\n}\nif (platformItems.length === 0) throw new Error('Keine aktiven Platform-Accounts konfiguriert.');\nreturn platformItems;"
      }
    },
